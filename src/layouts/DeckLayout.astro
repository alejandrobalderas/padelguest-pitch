---
/**
 * DeckLayout.astro — The global shell for every slide page.
 *
 * Each slide is a separate Astro page rendered with hard navigation. This
 * gives us atomic single-paint commits per slide (no half-rendered state).
 *
 * Responsibilities:
 *   - Set HTML lang, viewport, document title
 *   - Load global stylesheet (fonts + tokens + reset + slide-frame styles)
 *   - Inline-script: tag <html> as JS-enabled and compute slide-fitter values
 *     before first paint (eliminates the FOUC and the title "jump")
 *   - Preload slide image assets so cross-slide nav is instant
 *   - Mount slide-fitter (resize handler), deck-controller (nav), animations
 *   - Render the slide counter overlay
 */

import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

// Preload the Latin-subset woff2 files we actually use, so the browser
// has them in cache by the time CSS applies and GSAP starts animating.
// Without this, fallback fonts paint first and swap mid-animation,
// causing a visible layout shift (FOUT).
import instrumentSerifItalic from '@fontsource/instrument-serif/files/instrument-serif-latin-400-italic.woff2?url';
import inter400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import inter500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import inter600 from '@fontsource/inter/files/inter-latin-600-normal.woff2?url';
import inter700 from '@fontsource/inter/files/inter-latin-700-normal.woff2?url';
import geistMono600 from '@fontsource/geist-mono/files/geist-mono-latin-600-normal.woff2?url';
import geistMono700 from '@fontsource/geist-mono/files/geist-mono-latin-700-normal.woff2?url';

interface Props {
  title: string;
}

const { title } = Astro.props;
// BASE_URL is the configured `base` from astro.config.mjs (with trailing slash).
// Used to prefix every absolute asset path so the deck works under
// /padelguest-pitch/ on GitHub Pages.
const BASE = import.meta.env.BASE_URL;

// Custom @font-face declarations with `font-display: block`. The browser
// will WAIT for the font to load instead of swapping mid-render. Combined
// with the preload links below, the wait is invisibly short because the
// woff2 is already in cache by the time CSS evaluates.
const fontFaceCss = `
  @font-face {
    font-family: 'Instrument Serif';
    font-style: italic;
    font-weight: 400;
    font-display: block;
    src: url('${instrumentSerifItalic}') format('woff2');
  }
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 400;
    font-display: block;
    src: url('${inter400}') format('woff2');
  }
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 500;
    font-display: block;
    src: url('${inter500}') format('woff2');
  }
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 600;
    font-display: block;
    src: url('${inter600}') format('woff2');
  }
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 700;
    font-display: block;
    src: url('${inter700}') format('woff2');
  }
  @font-face {
    font-family: 'Geist Mono';
    font-style: normal;
    font-weight: 600;
    font-display: block;
    src: url('${geistMono600}') format('woff2');
  }
  @font-face {
    font-family: 'Geist Mono';
    font-style: normal;
    font-weight: 700;
    font-display: block;
    src: url('${geistMono700}') format('woff2');
  }
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1B3A28" />
    <meta name="description" content="PadelGuest — The missing layer between hotels and their padel courts." />

    <!-- FOUC prevention: tag the html element as JS-enabled BEFORE first paint.
         The CSS rule `html.js [data-anim] { opacity: 0 }` then hides animated
         elements from the very first frame, eliminating the "flash to final state"
         that happens when JS runs after the initial paint.
         No-JS users (no .js class) still see all content normally. -->
    <script is:inline>
      document.documentElement.classList.add('js');

      // Inline slide-fitter: compute scale + offsets BEFORE first paint so the
      // slide-frame is sized correctly on the very first frame of every page
      // load. Without this, the new document briefly paints with the default
      // `--slide-scale: 1` from tokens.css (unscaled 1920x1080), then the
      // deferred module script snaps it down — visible as a title "jump".
      (function () {
        var W = 1920, H = 1080;
        var s = Math.min(window.innerWidth / W, window.innerHeight / H);
        var x = (window.innerWidth  - W * s) / 2;
        var y = (window.innerHeight - H * s) / 2;
        var r = document.documentElement.style;
        r.setProperty('--slide-scale', String(s));
        r.setProperty('--slide-x', x + 'px');
        r.setProperty('--slide-y', y + 'px');
      })();
    </script>

    <title>{title} · PadelGuest</title>

    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />

    <!-- Font preloads: kick off the woff2 fetches in parallel with HTML
         parse so the FontFace cache is warm before first paint. crossorigin
         is required for the preload to dedupe with the @font-face fetch. -->
    <link rel="preload" as="font" type="font/woff2" href={instrumentSerifItalic} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter500} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter600} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter700} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={geistMono600} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={geistMono700} crossorigin />

    <!-- Custom @font-face with `font-display: block` — browser waits for the
         font instead of swapping. Paired with the preloads above, the wait
         is imperceptible. -->
    <style is:global set:html={fontFaceCss}></style>

    <!-- Image preloading: warm up all slide assets on first page visit so subsequent
         navigation between slides is instant. Total ~1.2MB, fetched in parallel.
         After the first page, the browser cache makes every other slide free. -->
    <link rel="preload" as="image" href={`${BASE}slide-assets/registration.png`} />
    <link rel="preload" as="image" href={`${BASE}slide-assets/available-matches.png`} />
    <link rel="preload" as="image" href={`${BASE}slide-assets/whatsapp-flow.png`} />
    <link rel="preload" as="image" href={`${BASE}slide-assets/stripe-checkout.png`} />
    <link rel="preload" as="image" href={`${BASE}slide-assets/match-confirmed.png`} />
    <link rel="preload" as="image" href={`${BASE}slide-assets/dashboard.png`} />

    <!-- Astro view transitions: SPA-style swap with preserved <html>.
         The keyframe animation is killed in global.css; we keep ClientRouter
         only for prefetching and persistent script context. -->
    <ClientRouter />
  </head>

  <body>
    <slot />

    <!-- Slide counter overlay (fixed bottom-right) -->
    <div id="slide-counter" class="slide-counter" aria-hidden="true"></div>

    <!-- Scripts: fitter (CSS scaling) + deck controller (keyboard / swipe / nav)
         + slide animations (single global file, scoped per slide) -->
    <script>
      import '../scripts/slide-fitter';
      import '../scripts/deck-controller';
      import '../scripts/slide-animations';
    </script>

    <style>
      .slide-counter {
        position: fixed;
        bottom: 20px;
        right: 24px;
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: var(--accent-gold);
        opacity: 0.6;
        z-index: 100;
        pointer-events: none;
        user-select: none;
      }
    </style>
  </body>
</html>
