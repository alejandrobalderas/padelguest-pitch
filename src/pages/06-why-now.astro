---
import DeckLayout from '../layouts/DeckLayout.astro';
import Slide from '../components/Slide.astro';
import SlideHeader from '../components/SlideHeader.astro';
---

<DeckLayout title="Why Now">
  <Slide bg="cream" index={6}>
    <SlideHeader
      label="06  ·  WHY NOW"
      title="Three curves bending at once."
    />

    <div class="slide-body" data-slide-anim="whynow">
      <div class="row">
        <div class="col" data-anim="col">
          <p class="num gold">+25%</p>
          <div class="rule"></div>
          <p class="head">Padel growth, every year.</p>
          <p class="body">
            30M+ players globally. Mexico is 4th in the world (1M+ players, 630+ clubs).
            Cancún hosts the Premier Padel P2 every year.
          </p>
        </div>

        <div class="col" data-anim="col">
          <p class="num">3M → 36M</p>
          <div class="rule"></div>
          <p class="head">The pickleball precedent.</p>
          <p class="body">
            US pickleball went from 3M to 36M players in 10 years (2013–2023).
            Same social dynamics, same low learning curve. Padel is following
            the same trajectory globally.
          </p>
        </div>

        <div class="col" data-anim="col">
          <p class="num gold">2–3 yrs</p>
          <div class="rule"></div>
          <p class="head">Then the window closes.</p>
          <p class="body">
            In 2–3 years, hotels will install courts and build the software themselves.
            The land grab for the operating layer is happening now.
          </p>
        </div>
      </div>
    </div>
  </Slide>
</DeckLayout>

<style>
  .slide-body {
    justify-content: center;
  }

  .row {
    display: flex;
    flex-direction: row;
    gap: 60px;
    width: 100%;
    align-items: flex-start;
  }

  .col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: flex-start;
  }

  .num {
    font-family: var(--font-mono);
    font-size: 96px;
    font-weight: 600;
    line-height: 1;
    color: var(--foreground-primary);
    margin: 0;
  }
  .num.gold { color: var(--accent-gold); }

  .rule {
    width: 48px;
    height: 3px;
    background: var(--accent-gold);
  }

  .head {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 600;
    color: var(--foreground-primary);
    line-height: 1.3;
  }

  .body {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: var(--foreground-secondary);
    line-height: 1.5;
  }
</style>

<!-- Animation handled by global slide-animations.ts (dispatched via data-slide-anim="whynow") -->
