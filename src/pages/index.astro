---
import DeckLayout from '../layouts/DeckLayout.astro';
import Slide from '../components/Slide.astro';
import SlideHeader from '../components/SlideHeader.astro';
---

<DeckLayout title="Cover">
  <Slide bg="forest" index={1}>
    <SlideHeader label="HOSPITALITY  ·  PADEL  ·  TECH" tone="light" />

    <div class="cover-hero" data-slide-anim="cover">
      <h1 class="wordmark" data-anim="wordmark">Padel Guest</h1>
      <div class="gold-rule" data-anim="rule"></div>
      <p class="tagline" data-anim="tagline">
        New courts. New friends.
      </p>
    </div>

    <div class="cover-footer" data-anim="footer">
      <span class="footer-left">padelguest.com</span>
      <span class="footer-right">April 2026  ·  Pre-seed</span>
    </div>
  </Slide>
</DeckLayout>

<style>
  /* Hero block — absolute-positioned for the cover wordmark */
  .cover-hero {
    position: absolute;
    top: 360px;
    left: 140px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 44px;
    color: var(--foreground-inverse);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 220px;
    font-style: italic;
    font-weight: 400;
    line-height: 0.95;
    color: var(--foreground-inverse);
    margin: 0;
  }

  .gold-rule {
    width: 160px;
    height: 6px;
    background: var(--accent-gold);
    border-radius: 9999px;
    transform-origin: left;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: 54px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.25;
    color: var(--foreground-inverse);
    opacity: 0.88;
    max-width: 1300px;
    margin: 0;
  }

  .cover-footer {
    position: absolute;
    bottom: 80px;
    left: 140px;
    right: 140px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 22px;
    font-weight: 500;
    color: var(--foreground-inverse);
  }

  .footer-left { color: var(--accent-gold); }
  .footer-right { opacity: 0.55; }
</style>

<!-- Animation handled by global slide-animations.ts (dispatched via data-slide-anim="cover") -->
